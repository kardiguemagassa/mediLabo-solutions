# ╔════════════════════════════════════════════════════════════════════════════╗
# ║              MEDILABO SOLUTIONS - Environment Variables Template           ║
# ║                                                                            ║
# ║  📋 INSTRUCTIONS:                                                          ║
# ║  1. Copy this file to .env:  cp .env.example .env                          ║
# ║  2. Fill in your actual values                                             ║
# ║  3. NEVER commit .env to git                                               ║
# ║                                                                            ║
# ║  🔒 SECURITY: This template contains NO real credentials                   ║
# ╚════════════════════════════════════════════════════════════════════════════╝


# ENVIRONMENT
# Options: dev | prod | test
SPRING_PROFILES_ACTIVE=dev


# POSTGRESQL
# For local development: localhost
# For Docker: host.docker.internal (Mac/Windows) or 172.17.0.1 (Linux)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USERNAME=
POSTGRES_PASSWORD=


# Database names per service
POSTGRES_DB_AUTHORIZATION=medilabo_authorization
POSTGRES_DB_PATIENTS=medilabo_patients
POSTGRES_DB_ASSESSMENT=medilabo_assessment
POSTGRES_DB_NOTIFICATION=medilabo_notification


# MONGODB (Notes Service only)
MONGO_HOST=
MONGO_PORT=27017
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_DATABASE=medilabo_notes
# Set to true if MongoDB requires authentication
MONGO_AUTH_ENABLED=false


# EUREKA (Service Discovery)
# Credentials for Eureka dashboard access (stored in PostgreSQL)
EUREKA_USERNAME=
EUREKA_PASSWORD=
# Eureka server hostname
# For local: localhost
# For Docker: discovery-server
EUREKA_HOST=localhost
EUREKA_PORT=8761


# SERVICES CONFIGURATION
DISCOVERY_SERVER_PORT=8761
AUTHORIZATION_SERVER_PORT=9001
GATEWAY_PORT=8080
PATIENT_SERVICE_PORT=8081
NOTES_SERVICE_PORT=8082
ASSESSMENT_SERVICE_PORT=8083
NOTIFICATION_SERVICE_PORT=8084


# SERVICES HOSTS (Docker only - uncomment for docker-compose)
# AUTHORIZATION_SERVER_HOST=authorization-server
# GATEWAY_HOST=gateway
# PATIENT_SERVICE_HOST=patient-service
# NOTES_SERVICE_HOST=notes-service
# ASSESSMENT_SERVICE_HOST=assessment-service


# OAUTH2 / JWT
# For local: http://localhost:9001/oauth2/jwks
# For Docker: http://authorization-server:9001/oauth2/jwks
JWKS_URI=http://localhost:9001/oauth2/jwks


# Frontend URL for CORS and OAuth2 redirects
UI_APP_URL=http://localhost:4200


# RSA KEYS (Authorization Server only)
# Paths to RSA key files for JWT signing
#
# FOR LOCAL DEVELOPMENT (IntelliJ):
#   - Keys are in src/main/resources/keys/
#   - Use just the filename (code adds the path prefix)
#   RSA_PRIVATE_KEY_PATH=private.key
#   RSA_PUBLIC_KEY_PATH=public.key
#
# FOR DOCKER:
#   - Keys are mounted from .keys/ to /app/keys/ in container
#   - Use absolute container path
#   RSA_PRIVATE_KEY_PATH=/app/keys/private.key
#   RSA_PUBLIC_KEY_PATH=/app/keys/public.key
#
# Generate keys with:
#   openssl genrsa -out private.key 2048
#   openssl rsa -in private.key -pubout -out public.key
RSA_PRIVATE_KEY_PATH=private.key
RSA_PUBLIC_KEY_PATH=public.key


# LOGGING
# Options: TRACE | DEBUG | INFO | WARN | ERROR
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=WARN
LOG_LEVEL_SQL=WARN


# KAFKA (Notification Service only)
# For local: localhost:9092
# For Docker: kafka:9092
KAFKA_SERVER_URL=localhost:9092


# EMAIL / SMTP (Notification Service only)
# Gmail SMTP example (use App Password, not your regular password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
# Email verification link host
VERIFY_EMAIL_HOST=http://localhost:4200


# DOCKER (Production only)
DOCKER_REGISTRY=localhost:8186
IMAGE_TAG=latest
